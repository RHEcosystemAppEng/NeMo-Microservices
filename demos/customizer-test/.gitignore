# Python bytecode and cache files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Environment variables (NEVER commit secrets!)
env.donotcommit
.env
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Model files (can be large)
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
# Downloaded model directories (from DataStore/PVC)
downloaded_model/
downloaded_model_*/
# Merged model directories (from merge script)
merged_model/
merged_model_*/
# Model export directories
model_export_*/
# Model info JSON files (may contain sensitive paths)
model_info*.json
# Base model test responses (notebook output)
base_model_responses.json
base_model_responses.txt
# Customized model test responses (for comparison with base)
customized_model_responses.json
customized_model_responses.txt

# Temporary files
*.tmp
*.log
*.pid
/tmp/nemo_port_forwards_*.pids

# OS files
.DS_Store
Thumbs.db
