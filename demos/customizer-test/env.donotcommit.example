# NeMo Microservices Configuration
# Copy this file to env.donotcommit and fill in your values
# ⚠️ NEVER commit env.donotcommit - it's in .gitignore

# Namespace where NeMo services are deployed
NMS_NAMESPACE=anemo-rhoai

# NeMo Data Store token (optional, defaults to "token")
NDS_TOKEN=token

# NGC API Key (for pulling NVIDIA images and accessing NGC)
NGC_API_KEY=

# Hugging Face token (for accessing Hugging Face datasets and models)
HF_TOKEN=

# NIM Service Account Token (for InferenceService authentication)
# Get your token: oc create token <service-account-name> -n <namespace> --duration=8760h
NIM_SERVICE_ACCOUNT_TOKEN=

# Service URLs (for local development with port-forwards)
# If running scripts from local machine, use localhost URLs
# If running in cluster (notebooks), these will use cluster-internal URLs automatically
DATASTORE_URL=http://localhost:8001
ENTITY_STORE_URL=http://localhost:8002
CUSTOMIZER_URL=http://localhost:8003

# Inference Service Configuration (for testing models)
# URL of your InferenceService (e.g., http://your-inference-service:8000)
INFERENCE_SERVICE_URL=

# Inference Service name (optional, for reference)
INFERENCE_SERVICE_NAME=

# Base model name (e.g., meta/llama-3.2-1b-instruct)
BASE_MODEL=meta/llama-3.2-1b-instruct

# Customization template (e.g., meta/llama-3.2-1b-instruct@v1.0.0)
CUSTOMIZATION_TEMPLATE=meta/llama-3.2-1b-instruct@v1.0.0

# Customized model name (from completed customization job; used by test-customized-model.ipynb and export scripts)
# Format: <namespace>/llama-3.2-1b-instruct-custom-<timestamp>-<id>@1.0
CUSTOMIZED_MODEL_NAME=
